{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@shared/*":       ["shared/*"],
      "@atomic/*":       ["atomic_bot/*"],
      "@jkt48/*":        ["jkt48_bot/*"],
      "@bypass/*":       ["bypass_bot/*"],
      "@startup/*":      ["startup/*"],

      "@constants/*":    ["shared/constants/*"],
      "@enums/*":        ["shared/enums/*"],
      "@models/*":       ["shared/models/*"],

      "@utils":          ["shared/utils"],
      "@utils/*":        ["shared/utils/*"],
      "@config":         ["shared/config"],
      "@config/*":       ["shared/config/*"],
      "@database":       ["shared/database"],
      "@database/*":     ["shared/database/*"],
      "@managers":       ["shared/database/managers"],
      "@managers/*":     ["shared/database/managers/*"],
      "@services":       ["shared/database/services"],
      "@services/*":     ["shared/database/services/*"],

      "@discord":        ["atomic_bot/discord"],
      "@discord/*":      ["atomic_bot/discord/*"],
      "@http":           ["atomic_bot/http"],
      "@http/*":         ["atomic_bot/http/*"],
      "@commands":       ["atomic_bot/features/commands"],
      "@commands/*":     ["atomic_bot/features/commands/*"],
      "@integrations":   ["atomic_bot/integrations"],
      "@integrations/*": ["atomic_bot/integrations/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "sourceMap": false,
    "declaration": false,
    "removeComments": true,
    "importHelpers": false,
    "downlevelIteration": false,
    "isolatedModules": false,
    "noEmitOnError": false,
    "preserveConstEnums": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts", "web/**/*", ".trash/**/*"]
}
